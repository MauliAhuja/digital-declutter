schemeClr val="tx1"/></a:solidFill><a:highlight><a:srgbClr val="00FFFF"/></a:highlight><a:latin typeface="+mn-lt"/></a:rPr><a:t>Unemployed youth face difficulty in identifying suitable career paths and accessing personalized, affordable skill development opportunities due to lack of guidance, awareness, and real-time job market information</a:t></a:r><a:r><a:rPr lang="en-US" sz="3200" dirty="0"><a:highlight><a:srgbClr val="00FFFF"/></a:highlight><a:latin typeface="+mn-lt"/></a:rPr><a:t>.</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" sz="3200" dirty="0"><a:latin typeface="+mn-lt"/></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="en-US" sz="3200" b="1" dirty="0"><a:latin typeface="+mn-lt"/></a:rPr><a:t>🔍 </a:t></a:r><a:r><a:rPr lang="en-US" sz="4000" b="1" dirty="0"><a:latin typeface="+mn-lt"/></a:rPr><a:t>Key Issues Identified:</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-457200"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="3200" dirty="0"><a:latin typeface="+mn-lt"/></a:rPr><a:t>Skill mismatch between education and industry demand</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-457200"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="3200" dirty="0"><a:latin typeface="+mn-lt"/></a:rPr><a:t>Lack of personalized career direction</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-457200"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="3200" dirty="0"><a:latin typeface="+mn-lt"/></a:rPr><a:t>Limited access to career counseling</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-457200"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="3200" dirty="0"><a:latin typeface="+mn-lt"/></a:rPr><a:t>Language and digital literacy barriers</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-457200"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="3200" dirty="0"><a:latin typeface="+mn-lt"/></a:rPr><a:t>Generic job portals without targeted recommendations</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-IN" sz="3200" dirty="0"><a:latin typeface="+mn-lt"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="4" name="object 7"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{B9D618DB-A7FE-BC45-1B61-78B8D669B03A}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="304800" y="109220"/><a:ext cx="1071880" cy="1071880"/></a:xfrm><a:custGeom><a:avLst/><a:gdLst/><a:ahLst/><a:cxnLst/><a:rect l="l" t="t" r="r" b="b"/><a:pathLst><a:path w="1071879" h="1071880"><a:moveTo><a:pt x="535781" y="1071562"/></a:moveTo><a:lnTo><a:pt x="527576" y="1005282"/></a:lnTo><a:lnTo><a:pt x="519179" y="945248"/></a:lnTo><a:lnTo><a:pt x="510234" y="891106"/></a:lnTo><a:lnTo><a:pt x="500387" y="842500"/></a:lnTo><a:lnTo><a:pt x="489282" y="799075"/></a:lnTo><a:lnTo><a:pt x="476564" y="760475"/></a:lnTo><a:lnTo><a:pt x="444867" y="696331"/></a:lnTo><a:lnTo><a:pt x="402453" y="647224"/></a:lnTo><a:lnTo><a:pt x="346479" y="610311"/></a:lnTo><a:lnTo><a:pt x="274103" y="582751"/></a:lnTo><a:lnTo><a:pt x="230876" y="571589"/></a:lnTo><a:lnTo><a:pt x="182483" y="561700"/></a:lnTo><a:lnTo><a:pt x="128568" y="552726"/></a:lnTo><a:lnTo><a:pt x="68776" y="544315"/></a:lnTo><a:lnTo><a:pt x="0" y="535781"/></a:lnTo><a:lnTo><a:pt x="66412" y="527558"/></a:lnTo><a:lnTo><a:pt x="126553" y="519142"/></a:lnTo><a:lnTo><a:pt x="180778" y="510176"/></a:lnTo><a:lnTo><a:pt x="229447" y="500301"/></a:lnTo><a:lnTo><a:pt x="272916" y="489159"/></a:lnTo><a:lnTo><a:pt x="31154